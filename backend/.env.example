DATABASE_URL="postgresql://university_user:university_pass_2024@localhost:5432/university_db?schema=public"

PORT=4000
FRONTEND_URL="http://localhost:3000"

# openssl rand -hex 32
JWT_SECRET=""
JWT_EXPIRES_IN="1d"
# TTL del token cuando el usuario marca "Recordarme" en el login.
JWT_REMEMBER_EXPIRES_IN="30d"

REDIS_URL="redis://localhost:6379"

# Correo transaccional (SMTP) para enviar credenciales al registrar usuarios.
# Agnóstico al proveedor: Brevo (recomendado, 300/día gratis), Resend, Gmail…
# Si se deja vacío, la app funciona pero NO envía correos (solo lo registra).
# Ejemplo Brevo: SMTP_HOST="smtp-relay.brevo.com" SMTP_PORT=587
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# Remitente visible (idealmente un dominio verificado). Por defecto usa SMTP_USER.
SMTP_FROM="Certificate <no-reply@certificate.bo>"
# Link de login en el correo. Opcional: por defecto usa el primer origen de
# FRONTEND_URL + "/login". Útil cuando FRONTEND_URL lista varios orígenes
# (dev + prod) y el correo debe apuntar siempre al dominio público real.
# MAIL_LOGIN_URL="https://certificatebolivia.com.bo/login"

# Garage (S3-compatible) — must match docker-compose.yml
S3_ENDPOINT="http://localhost:3900"
S3_REGION="garage"
S3_BUCKET="university-files"
S3_ACCESS_KEY="garage_access_key"
S3_SECRET_KEY="garage_secret_key_2024"
