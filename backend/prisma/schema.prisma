generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PROFESSOR
  STUDENT
}

// ── Academia / LMS ──────────────────────────────────────────────────────────
// Enums de la capa académica. Es independiente del marketing (Program/landing):
// Course/CourseModule son entidades reales, no los textos de ProgramModule.

enum CourseStatus {
  DRAFT // en preparación, aún no visible para estudiantes
  ACTIVE // en curso
  FINISHED // concluido
  ARCHIVED // archivado
}

enum ModuleStatus {
  DRAFT
  ACTIVE
  FINISHED
}

enum EnrollmentStatus {
  ACTIVE // cursando
  WITHDRAWN // retirado
  GRADUATED // egresado / curso concluido
}

enum ActivityType {
  ASSIGNMENT // tarea
  QUIZ // cuestionario
  EXAM // examen
  PROJECT // proyecto
  FORUM // foro / participación
}

enum SubmissionStatus {
  PENDING // sin entregar
  SUBMITTED // entregada a tiempo
  LATE // entregada con retraso
  GRADED // calificada
}

enum MaterialType {
  FILE // archivo subido (Garage/S3, ruta /files/...)
  LINK // enlace externo
  VIDEO // video (enlace o embebido)
}

// Tipo de un contenido del temario (entrada de ModuleContent). El docente elige
// uno al crear cada contenido.
enum ContentKind {
  TEXT // tema editable (texto enriquecido / HTML)
  VIDEO // video embebido (YouTube/Vimeo)
  MATERIAL // archivo subido o enlace externo
  ACTIVITY // actividad evaluable (con entrega y nota)
}

enum ModuleGradeStatus {
  IN_PROGRESS // en curso, sin nota final
  PASSED // aprobado
  FAILED // reprobado
}

// Tipo de notificación dirigida a un usuario (docente/estudiante).
enum NotificationType {
  ENROLLMENT // estudiante inscrito en un programa/curso
  MODULE_ASSIGNMENT // docente asignado a un módulo (co-docencia)
  ANNOUNCEMENT // aviso manual enviado por un administrador
  GRADE // el docente calificó una actividad del estudiante
  ACTIVITY_PUBLISHED // se publicó una nueva actividad en un módulo
}

// Configuración global de la landing (fila única / singleton). Guarda los
// enlaces a las redes sociales; un valor null/ausente oculta su icono.
model SiteSettings {
  id        String   @id @default("singleton")
  facebook  String?
  instagram String?
  linkedin  String?
  youtube   String?
  tiktok    String?
  whatsapp  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName  String
  lastName   String
  phone      String // teléfono de contacto (obligatorio)
  idDocument String? // documento de identidad / carnet (opcional)
  role       Role     @default(STUDENT)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relaciones académicas (rol PROFESSOR / STUDENT). Un User puede tener
  // varias de estas según su rol; todas son opcionales para ADMIN.
  taughtModules     ModuleTeacher[] // co-docencia: módulos que dicta (vía join)
  enrollments       Enrollment[]
  submissions       Submission[]
  gradedSubmissions Submission[]   @relation("SubmissionGrader")
  moduleGrades      ModuleGrade[]  @relation("StudentGrades")
  gradedModules     ModuleGrade[]  @relation("ModuleGrader")
  notifications     Notification[]
  sentAnnouncements Announcement[]    @relation("AnnouncementSender")
  contentProgress   ContentProgress[]
  contentNotes      ContentNote[]

  @@map("users")
}

// Audiencia a la que un administrador dirigió un aviso (para el historial).
enum AnnouncementAudience {
  ALL // docentes y estudiantes
  PROFESSORS // todos los docentes
  STUDENTS // todos los estudiantes
  SELECTED // lista explícita de usuarios
}

// Registro (log) de cada aviso que un administrador envía. Una fila por envío
// —no por destinatario—, con cuántas notificaciones generó. Alimenta el
// "historial de avisos enviados" del panel.
model Announcement {
  id             String               @id @default(uuid())
  title          String
  body           String
  audience       AnnouncementAudience
  recipientCount Int
  senderId       String
  sender         User                 @relation("AnnouncementSender", fields: [senderId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now())

  @@index([createdAt])
  @@map("announcements")
}

// Notificación persistida para un usuario (docente/estudiante). Se crea al
// inscribir a un estudiante en un programa o asignar a un docente a un módulo;
// el panel la lee vía GET /notifications y la marca como leída.
model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  readAt    DateTime?
  // Contexto opcional para enlazar/mostrar (ej. { courseId, moduleId }). Sin FK
  // dura: si el curso/módulo se borra, la notificación histórica se conserva.
  data      Json?
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model ProgramCategory {
  id           String    @id @default(uuid())
  name         String
  slug         String    @unique
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  programs     Program[]

  @@map("program_categories")
}

model Partner {
  id           String   @id @default(uuid())
  name         String
  logoUrl      String   @unique // ruta pública servida por el frontend, ej. /landing/partners/2.webp
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isPublished, displayOrder])
  @@map("partners")
}

model TeamMember {
  id           String   @id @default(uuid())
  name         String
  role         String // cargo, ej. "Gerente General / Representante Legal"
  photoUrl     String // ruta pública servida por el frontend, ej. /files/team/<uuid>.webp
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isPublished, displayOrder])
  @@map("team_members")
}

model Program {
  id                String          @id @default(uuid())
  slug              String          @unique
  title             String
  categoryId        String
  category          ProgramCategory @relation(fields: [categoryId], references: [id])
  flyerUrl          String // ruta pública servida por el frontend, ej. /landing/program/programa1.webp
  objective         String
  targetAudience    String
  modality          String
  startDate         DateTime
  duration          String
  schedule          String
  requirements      String[]
  enrollmentFee     Decimal         @db.Decimal(10, 2)
  totalCost         Decimal         @db.Decimal(10, 2)
  currency          String          @default("Bs")
  paymentFacilities String?
  isPublished       Boolean         @default(true)
  displayOrder      Int             @default(0) // orden manual (drag-and-drop del panel); también rige el orden en la landing
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  modules  ProgramModule[]
  teachers ProgramTeacher[]

  @@index([categoryId, isPublished])
  @@map("programs")
}

model ProgramModule {
  id        String   @id @default(uuid())
  programId String
  order     Int
  name      String
  contents  String[]
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, order])
  @@map("program_modules")
}

model ProgramTeacher {
  id          String  @id @default(uuid())
  programId   String
  fullName    String
  credentials String
  photoUrl    String?
  order       Int     @default(0)
  program     Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("program_teachers")
}

// ── Academia / LMS ──────────────────────────────────────────────────────────
// Capa académica real, separada del marketing de la landing. El admin crea
// cursos y módulos, asigna docentes (User PROFESSOR) e inscribe estudiantes
// (User STUDENT). El docente crea temas, materiales y actividades dentro de un
// módulo. El estudiante accede a los módulos del curso en que está inscrito y
// acumula notas por módulo (kárdex = sus ModuleGrade).

// Curso académico. Entidad independiente de Program (landing). El admin lo crea.
model Course {
  id           String       @id @default(uuid())
  code         String       @unique // código institucional, ej. "MBA-2026-I"
  name         String
  description  String?
  modality     String? // ej. "Virtual con clases en vivo"
  startDate    DateTime?
  endDate      DateTime?
  passingScore Decimal      @default(70) @db.Decimal(5, 2) // nota mínima de aprobación
  status       CourseStatus @default(DRAFT)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  modules     CourseModule[]
  enrollments Enrollment[]

  @@index([status])
  @@map("courses")
}

// Módulo académico dentro de un curso, dictado por un docente.
model CourseModule {
  id          String       @id @default(uuid())
  courseId    String
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order       Int // posición del módulo en la malla del curso
  name        String
  description String?
  credits     Int?
  startDate   DateTime?
  endDate     DateTime?
  status      ModuleStatus @default(ACTIVE) // el admin puede marcarlo Borrador/Concluido
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  teachers ModuleTeacher[] // co-docencia: varios docentes por módulo
  contents ModuleContent[] // contenidos ordenados (temario): tema/video/material/actividad
  grades   ModuleGrade[]

  @@unique([courseId, order])
  @@map("course_modules")
}

// Asignación docente↔módulo (co-docencia: un módulo puede tener varios docentes
// y un docente varios módulos). Reemplaza el antiguo CourseModule.teacherId.
model ModuleTeacher {
  id         String       @id @default(uuid())
  moduleId   String
  module     CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  teacherId  String // docente asignado (User PROFESSOR)
  teacher    User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  assignedAt DateTime     @default(now())

  @@unique([moduleId, teacherId])
  @@index([teacherId])
  @@map("course_module_teachers")
}

// Inscripción de un estudiante a un curso. Le da acceso a todos sus módulos.
model Enrollment {
  id         String           @id @default(uuid())
  studentId  String
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId   String
  course     Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([studentId, courseId])
  @@index([courseId])
  @@map("enrollments")
}

// Contenido de un módulo: una entrada del temario. El docente crea contenidos y
// elige su tipo (TEXT/VIDEO/MATERIAL/ACTIVITY). Cada contenido tiene título y un
// `order` reordenable (drag-and-drop) que define cómo aparece en el temario del
// estudiante. Los campos específicos del tipo son anulables y solo aplican según
// `kind`.
model ModuleContent {
  id          String       @id @default(uuid())
  moduleId    String
  module      CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  order       Int // posición en el temario (reordenable)
  kind        ContentKind
  title       String
  isPublished Boolean      @default(true)

  // TEXT — tema editable
  body String? // texto enriquecido (HTML)

  // VIDEO — video embebido
  videoUrl String? // enlace YouTube/Vimeo

  // MATERIAL — archivo o enlace
  materialType MaterialType? // FILE | LINK
  url          String? // ruta /files/... (subida) o enlace externo

  // ACTIVITY — actividad evaluable
  activityType ActivityType?
  instructions String?
  dueDate      DateTime?
  maxScore     Decimal?      @db.Decimal(5, 2)
  weight       Decimal?      @db.Decimal(5, 2) // peso (%) en la nota del módulo
  // Actividad "presencial": la califica el docente a mano en la libreta (sin
  // entrega digital del estudiante). No aparece en el temario del aula; sí
  // pondera en la nota del módulo y se muestra en las notas del estudiante.
  isOffline    Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions Submission[]
  progress    ContentProgress[]
  notes       ContentNote[]

  @@unique([moduleId, order])
  @@index([moduleId])
  @@map("module_contents")
}

// Progreso de un estudiante en un contenido: si lo marcó como completado.
// Alimenta el porcentaje de avance del módulo en la vista de aprendizaje.
model ContentProgress {
  id          String        @id @default(uuid())
  studentId   String
  student     User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  contentId   String
  content     ModuleContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  completed   Boolean       @default(false)
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([studentId, contentId])
  @@index([contentId])
  @@map("content_progress")
}

// Apuntes personales de un estudiante sobre un contenido. Privados: solo los ve
// su autor ("Tus notas").
model ContentNote {
  id        String        @id @default(uuid())
  studentId String
  student   User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  contentId String
  content   ModuleContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  body      String // texto del apunte
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([studentId, contentId])
  @@index([contentId])
  @@map("content_notes")
}

// Entrega de un estudiante para un contenido de tipo ACTIVITY. Calificada por el
// docente.
model Submission {
  id          String           @id @default(uuid())
  contentId   String
  content     ModuleContent    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  studentId   String
  student     User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  text        String? // texto de la entrega
  fileUrl     String? // archivo adjunto (ruta /files/...)
  status      SubmissionStatus @default(PENDING)
  score       Decimal?         @db.Decimal(5, 2)
  feedback    String?
  submittedAt DateTime?
  gradedById  String?
  gradedBy    User?            @relation("SubmissionGrader", fields: [gradedById], references: [id], onDelete: SetNull)
  gradedAt    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([contentId, studentId])
  @@index([studentId])
  @@map("submissions")
}

// Nota final de un estudiante en un módulo. El conjunto de las notas de un
// estudiante conforma su kárdex.
model ModuleGrade {
  id           String            @id @default(uuid())
  studentId    String
  student      User              @relation("StudentGrades", fields: [studentId], references: [id], onDelete: Cascade)
  moduleId     String
  module       CourseModule      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  finalScore   Decimal?          @db.Decimal(5, 2)
  status       ModuleGradeStatus @default(IN_PROGRESS)
  observations String?
  gradedById   String?
  gradedBy     User?             @relation("ModuleGrader", fields: [gradedById], references: [id], onDelete: SetNull)
  gradedAt     DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([studentId, moduleId])
  @@index([moduleId])
  @@map("module_grades")
}
