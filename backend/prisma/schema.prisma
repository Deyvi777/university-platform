generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PROFESSOR
  STUDENT
}

enum Gender {
  MALE
  FEMALE
}

// ── Academia / LMS ──────────────────────────────────────────────────────────
// Enums de la capa académica. Es independiente del marketing (Program/landing):
// Course/CourseModule son entidades reales, no los textos de ProgramModule.

enum CourseStatus {
  DRAFT // en preparación, aún no visible para estudiantes
  ACTIVE // en curso
  FINISHED // concluido
  ARCHIVED // archivado
}

enum ModuleStatus {
  DRAFT
  ACTIVE
  FINISHED
}

enum EnrollmentStatus {
  ACTIVE // cursando
  WITHDRAWN // retirado
  GRADUATED // egresado / curso concluido
}

enum ActivityType {
  ASSIGNMENT // tarea
  QUIZ // cuestionario
  EXAM // examen
  PROJECT // proyecto
  FORUM // foro / participación
}

// Tipo de pregunta del motor de Cuestionario/Examen.
enum QuestionType {
  SINGLE_CHOICE // opción múltiple, una correcta
  MULTIPLE_CHOICE // opción múltiple, varias correctas
  TRUE_FALSE // verdadero / falso
  SHORT_TEXT // respuesta corta (autocalificada por coincidencia)
  ESSAY // respuesta abierta (la califica el docente)
}

// Estado del intento de un estudiante en un cuestionario/examen.
enum QuizAttemptStatus {
  IN_PROGRESS // iniciado, sin enviar
  SUBMITTED // enviado, con ensayos pendientes de corrección manual
  GRADED // calificado del todo (auto + ensayos)
}

enum SubmissionStatus {
  PENDING // sin entregar
  SUBMITTED // entregada a tiempo
  LATE // entregada con retraso
  GRADED // calificada
}

enum MaterialType {
  FILE // archivo subido (Garage/S3, ruta /files/...)
  LINK // enlace externo
  VIDEO // video (enlace o embebido)
}

// Tipo de un contenido del temario (entrada de ModuleContent). El docente elige
// uno al crear cada contenido.
enum ContentKind {
  TEXT // tema editable (texto enriquecido / HTML)
  VIDEO // video embebido (YouTube/Vimeo)
  MATERIAL // archivo subido o enlace externo
  ACTIVITY // actividad evaluable (con entrega y nota)
  FOLDER // carpeta con varios archivos (descargable como ZIP)
}

enum ModuleGradeStatus {
  IN_PROGRESS // en curso, sin nota final
  PASSED // aprobado
  FAILED // reprobado
}

// Etapa de recuperación de una actividad QUIZ/EXAM. Un examen de recuperación
// se habilita sobre un módulo CONCLUIDO para los estudiantes reprobados; su
// nota NO pondera con las demás actividades: REEMPLAZA la nota final del
// módulo del estudiante que lo rinde.
enum RecoveryStage {
  RECUPERATORIO // lo habilita el docente (o admin) para los reprobados
  SEGUNDA_INSTANCIA // lo habilita SOLO el admin si se reprueba el recuperatorio
}

// Tipo de notificación dirigida a un usuario (docente/estudiante).
enum NotificationType {
  ENROLLMENT // estudiante inscrito en un programa/curso
  MODULE_ASSIGNMENT // docente asignado a un módulo (co-docencia)
  ANNOUNCEMENT // aviso manual enviado por un administrador
  GRADE // el docente calificó una actividad del estudiante
  ACTIVITY_PUBLISHED // se publicó una nueva actividad en un módulo
  MESSAGE // mensaje de chat recibido (docente ↔ estudiante en un módulo)
  MAIL_FAILED // aviso al ADMIN: el correo de credenciales de un usuario no se pudo enviar
  ENROLLMENT_REQUEST // aviso al ADMIN: llegó una solicitud de inscripción desde la landing
}

// Configuración global de la landing (fila única / singleton). Guarda los
// enlaces a las redes sociales; un valor null/ausente oculta su icono.
model SiteSettings {
  id        String   @id @default("singleton")
  facebook  String?
  instagram String?
  linkedin  String?
  youtube   String?
  tiktok    String?
  whatsapp  String?
  // Buzón que recibe el aviso por correo de cada solicitud de inscripción
  // (editable desde /dashboard/solicitudes). No se expone en el GET público.
  enrollmentNotifyEmail String @default("certificatebolivia@gmail.com")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName  String
  lastName   String
  phone      String // teléfono de contacto (obligatorio)
  idDocument String @unique // documento de identidad / carnet (obligatorio y único)
  issuedIn   String? // "expedido en": departamento/estado de emisión del documento (opcional)
  // Género (obligatorio). @default(MALE) permite añadir la columna con `db push`
  // sin perder datos: las filas existentes quedan en MALE, como se pidió.
  gender           Gender  @default(MALE)
  originUniversity String? // universidad de origen (opcional)
  profession       String? // profesión (opcional)
  role       Role     @default(STUDENT)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relaciones académicas (rol PROFESSOR / STUDENT). Un User puede tener
  // varias de estas según su rol; todas son opcionales para ADMIN.
  taughtModules     ModuleTeacher[] // co-docencia: módulos que dicta (vía join)
  enrollments       Enrollment[]
  submissions       Submission[]
  gradedSubmissions Submission[]   @relation("SubmissionGrader")
  moduleGrades      ModuleGrade[]  @relation("StudentGrades")
  gradedModules     ModuleGrade[]  @relation("ModuleGrader")
  notifications     Notification[]
  sentAnnouncements Announcement[]    @relation("AnnouncementSender")
  contentProgress   ContentProgress[]
  // Chat docente↔estudiante por módulo (mensajería directa).
  chatAsStudent ChatMessage[] @relation("ChatStudent")
  chatAsTeacher ChatMessage[] @relation("ChatTeacher")
  sentMessages  ChatMessage[] @relation("ChatSender")
  // Apuntes/recordatorios que el usuario marca en su calendario.
  calendarReminders CalendarReminder[]
  // Mensajes que el usuario publicó en foros de actividades.
  forumPosts ForumPost[]
  // Intentos de cuestionarios/exámenes del estudiante.
  quizAttempts QuizAttempt[]

  @@map("users")
}

// Apunte o recordatorio que un usuario marca en una fecha de su calendario
// (panel derecho del dashboard). Una fila por nota; varias notas por fecha.
model CalendarReminder {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date // fecha marcada (sin hora)
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@map("calendar_reminders")
}

// Audiencia a la que un administrador dirigió un aviso (para el historial).
enum AnnouncementAudience {
  ALL // docentes y estudiantes
  PROFESSORS // todos los docentes
  STUDENTS // todos los estudiantes
  SELECTED // lista explícita de usuarios
}

// Registro (log) de cada aviso que un administrador envía. Una fila por envío
// —no por destinatario—, con cuántas notificaciones generó. Alimenta el
// "historial de avisos enviados" del panel.
model Announcement {
  id             String               @id @default(uuid())
  title          String
  body           String
  audience       AnnouncementAudience
  recipientCount Int
  senderId       String
  sender         User                 @relation("AnnouncementSender", fields: [senderId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now())

  @@index([createdAt])
  @@map("announcements")
}

// Notificación persistida para un usuario (docente/estudiante). Se crea al
// inscribir a un estudiante en un programa o asignar a un docente a un módulo;
// el panel la lee vía GET /notifications y la marca como leída.
model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  readAt    DateTime?
  // Contexto opcional para enlazar/mostrar (ej. { courseId, moduleId }). Sin FK
  // dura: si el curso/módulo se borra, la notificación histórica se conserva.
  data      Json?
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model ProgramCategory {
  id           String    @id @default(uuid())
  name         String
  slug         String    @unique
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  programs     Program[]

  @@map("program_categories")
}

model Partner {
  id           String   @id @default(uuid())
  name         String
  logoUrl      String   @unique // ruta pública servida por el frontend, ej. /landing/partners/2.webp
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isPublished, displayOrder])
  @@map("partners")
}

enum GalleryMediaType {
  IMAGE
  VIDEO
}

model GalleryItem {
  id           String           @id @default(uuid())
  type         GalleryMediaType @default(IMAGE)
  url          String // ruta relativa subida al storage, ej. /files/gallery/<uuid>.webp
  title        String? // pie de foto opcional mostrado en la landing
  displayOrder Int              @default(0)
  isPublished  Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([isPublished, displayOrder])
  @@map("gallery_items")
}

model TeamMember {
  id           String   @id @default(uuid())
  name         String
  role         String // cargo, ej. "Gerente General / Representante Legal"
  photoUrl     String // ruta pública servida por el frontend, ej. /files/team/<uuid>.webp
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isPublished, displayOrder])
  @@map("team_members")
}

model Program {
  id                String          @id @default(uuid())
  slug              String          @unique
  title             String
  categoryId        String
  category          ProgramCategory @relation(fields: [categoryId], references: [id])
  flyerUrl          String // ruta pública servida por el frontend, ej. /landing/program/programa1.webp
  // Solo title/categoría/flyer son obligatorios: lo demás es opcional y la
  // landing oculta cada campo vacío.
  objective         String?
  specificObjectives String[]       @default([]) // objetivos específicos (viñetas en la landing)
  targetAudience    String?
  modality          String?
  startDate         DateTime?
  duration          String?
  hourlyLoad        String? // carga horaria, ej. "1200 horas académicas"
  schedule          String?
  // Video promocional: enlace YouTube/Vimeo o ruta /files/... de un archivo subido.
  videoUrl          String?
  extraFeatures     Json            @default("[]") // "más características": [{ label, value }]
  requirements      String[]
  // Opciones de pago (cada una con su moneda; vacías no se muestran en la landing):
  // "Pago al contado" = totalCost + currency; "Plan de cuotas" = installment*.
  enrollmentFee       Decimal?      @db.Decimal(10, 2) // matrícula (moneda = currency)
  totalCost           Decimal?      @db.Decimal(10, 2) // monto del pago al contado
  currency            String        @default("Bs") // moneda del contado y la matrícula
  installmentCount    Int? // nº de cuotas del plan
  installmentAmount   Decimal?      @db.Decimal(10, 2) // monto por cuota
  installmentCurrency String        @default("Bs")
  paymentFacilities   String?
  // Medios de pago:
  bankAccounts        Json          @default("[]") // [{ bank, accountNumber, holder }]
  qrImageUrl          String? // imagen QR de pago (ruta /files/...)
  isPublished       Boolean         @default(true)
  displayOrder      Int             @default(0) // orden manual (drag-and-drop del panel); también rige el orden en la landing
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  modules  ProgramModule[]
  teachers ProgramTeacher[]

  @@index([categoryId, isPublished])
  @@map("programs")
}

model ProgramModule {
  id        String   @id @default(uuid())
  programId String
  order     Int
  name      String
  contents  String[]
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, order])
  @@map("program_modules")
}

// Solicitud de inscripción enviada desde la landing (formulario público de un
// programa). Mismos datos que el alta de estudiante (sin contraseña) — el
// ADMIN la revisa en el panel y puede convertirla en cuenta STUDENT.
model EnrollmentRequest {
  id               String                  @id @default(uuid())
  firstName        String
  lastName         String
  email            String
  phone            String
  idDocument       String
  issuedIn         String // "expedido en"
  gender           Gender
  originUniversity String
  profession       String
  programTitle     String // nombre del programa desde el que se inscribió
  programSlug      String? // referencia suave (el programa puede borrarse)
  status           EnrollmentRequestStatus @default(PENDING)
  enrolledUserId   String? // id del User STUDENT creado al inscribirla
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([status, createdAt])
  @@map("enrollment_requests")
}

enum EnrollmentRequestStatus {
  PENDING
  ENROLLED
}

model ProgramTeacher {
  id          String  @id @default(uuid())
  programId   String
  fullName    String
  credentials String? // grado / especialidad (opcional)
  bio         String? // descripción / historial del docente
  photoUrl    String?
  order       Int     @default(0)
  program     Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("program_teachers")
}

// ── Academia / LMS ──────────────────────────────────────────────────────────
// Capa académica real, separada del marketing de la landing. El admin crea
// cursos y módulos, asigna docentes (User PROFESSOR) e inscribe estudiantes
// (User STUDENT). El docente crea temas, materiales y actividades dentro de un
// módulo. El estudiante accede a los módulos del curso en que está inscrito y
// acumula notas por módulo (kárdex = sus ModuleGrade).

// Curso académico. Entidad independiente de Program (landing). El admin lo crea.
model Course {
  id           String       @id @default(uuid())
  code         String       @unique // código institucional, ej. "MBA-2026-I"
  name         String
  description  String?
  icon         String? // clave de icono predefinido para las tarjetas (ej. "scale", "stethoscope")
  modality     String? // ej. "Virtual con clases en vivo"
  startDate    DateTime?
  endDate      DateTime?
  passingScore Decimal      @default(70) @db.Decimal(5, 2) // nota mínima de aprobación
  status       CourseStatus @default(DRAFT)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  modules     CourseModule[]
  enrollments Enrollment[]

  @@index([status])
  @@map("courses")
}

// Módulo académico dentro de un curso, dictado por un docente.
model CourseModule {
  id          String       @id @default(uuid())
  courseId    String
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order       Int // posición del módulo en la malla del curso
  name        String
  description String?
  credits     Int?
  startDate   DateTime?
  endDate     DateTime?
  status      ModuleStatus @default(ACTIVE) // el admin puede marcarlo Borrador/Concluido
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  teachers ModuleTeacher[] // co-docencia: varios docentes por módulo
  contents ModuleContent[] // contenidos ordenados (temario): tema/video/material/actividad
  grades   ModuleGrade[]
  messages ChatMessage[] // chat docente↔estudiante dentro del módulo
  classSessions ClassSession[] // cronograma de clases del módulo

  @@unique([courseId, order])
  @@map("course_modules")
}

// Una clase del cronograma de un módulo (creada por el docente/admin). El
// estudiante la ve en el aula y ambos en su calendario. Las horas se guardan
// como texto "HH:mm" (hora local de Bolivia): no hay zonas horarias que
// convertir y coincide 1:1 con los inputs del formulario.
model ClassSession {
  id        String       @id @default(uuid())
  moduleId  String
  module    CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  date      DateTime     @db.Date
  startTime String // "HH:mm"
  endTime   String? // "HH:mm", opcional
  title     String? // tema de la clase, ej. "Clase 3: Marco teórico"
  location  String? // aula física o enlace de la sesión virtual
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([moduleId, date])
  @@map("class_sessions")
}

// Asignación docente↔módulo (co-docencia: un módulo puede tener varios docentes
// y un docente varios módulos). Reemplaza el antiguo CourseModule.teacherId.
model ModuleTeacher {
  id         String       @id @default(uuid())
  moduleId   String
  module     CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  teacherId  String // docente asignado (User PROFESSOR)
  teacher    User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  assignedAt DateTime     @default(now())

  @@unique([moduleId, teacherId])
  @@index([teacherId])
  @@map("course_module_teachers")
}

// Inscripción de un estudiante a un curso. Le da acceso a todos sus módulos.
model Enrollment {
  id         String           @id @default(uuid())
  studentId  String
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId   String
  course     Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([studentId, courseId])
  @@index([courseId])
  @@map("enrollments")
}

// Contenido de un módulo: una entrada del temario. El docente crea contenidos y
// elige su tipo (TEXT/VIDEO/MATERIAL/ACTIVITY). Cada contenido tiene título y un
// `order` reordenable (drag-and-drop) que define cómo aparece en el temario del
// estudiante. Los campos específicos del tipo son anulables y solo aplican según
// `kind`.
model ModuleContent {
  id          String       @id @default(uuid())
  moduleId    String
  module      CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  order       Int // posición en el temario (reordenable)
  kind        ContentKind
  title       String
  isPublished Boolean      @default(true)

  // TEXT — tema editable
  body String? // texto enriquecido (HTML)

  // VIDEO — video embebido
  videoUrl String? // enlace YouTube/Vimeo

  // MATERIAL — archivo o enlace
  materialType MaterialType? // FILE | LINK
  url          String? // ruta /files/... (subida) o enlace externo

  // ACTIVITY — actividad evaluable
  activityType ActivityType?
  instructions String?
  dueDate      DateTime?
  maxScore     Decimal?      @db.Decimal(5, 2)
  weight       Decimal?      @db.Decimal(5, 2) // peso (%) en la nota del módulo
  // Actividad "presencial": la califica el docente a mano en la libreta (sin
  // entrega digital del estudiante). No aparece en el temario del aula; sí
  // pondera en la nota del módulo y se muestra en las notas del estudiante.
  isOffline    Boolean       @default(false)

  // ACTIVITY de tipo QUIZ/EXAM — configuración del motor de preguntas. Todos
  // nullable (solo aplican a cuestionarios/exámenes).
  timeLimitMin  Int? // duración límite en minutos (cronómetro); null = sin límite
  availableFrom DateTime? // ventana: no se puede rendir antes
  availableUntil DateTime? // ventana: no se puede rendir después
  singleAttempt Boolean? // true = un solo intento
  shuffle       Boolean? // barajar preguntas y opciones por estudiante
  revealAnswers Boolean? // resultados: true = corrección completa, false/null = solo nota
  // Examen de recuperación (solo QUIZ/EXAM, en módulo CONCLUIDO): su nota
  // reemplaza la nota final del módulo del estudiante que lo rinde. Máx. uno
  // por etapa por módulo. null = actividad normal (pondera por peso).
  recoveryStage RecoveryStage?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions Submission[]
  progress    ContentProgress[]
  folderFiles FolderFile[] // archivos contenidos (solo kind = FOLDER)
  forumPosts  ForumPost[] // mensajes del foro (solo activityType = FORUM)
  questions   Question[] // preguntas (solo QUIZ/EXAM)
  quizAttempts QuizAttempt[] // intentos de los estudiantes (solo QUIZ/EXAM)

  @@unique([moduleId, order])
  @@index([moduleId])
  @@map("module_contents")
}

// Archivo dentro de una carpeta (ModuleContent de kind = FOLDER). El docente
// sube varios; el estudiante los ve indentados y puede descargarlos (o todos en
// un ZIP, que se arma en el cliente).
model FolderFile {
  id        String        @id @default(uuid())
  contentId String
  content   ModuleContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  order     Int // posición dentro de la carpeta
  name      String // nombre visible (nombre original del archivo)
  url       String // ruta /files/...
  size      Int? // tamaño en bytes (opcional)
  createdAt DateTime @default(now())

  @@index([contentId])
  @@map("folder_files")
}

// Progreso de un estudiante en un contenido: si lo marcó como completado.
// Alimenta el porcentaje de avance del módulo en la vista de aprendizaje.
model ContentProgress {
  id          String        @id @default(uuid())
  studentId   String
  student     User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  contentId   String
  content     ModuleContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  completed   Boolean       @default(false)
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([studentId, contentId])
  @@index([contentId])
  @@map("content_progress")
}

// Mensaje de chat directo (1 a 1) entre un docente y un estudiante dentro de un
// módulo. La conversación se identifica por la terna (moduleId, studentId,
// teacherId); `senderId` (== studentId o teacherId) indica la dirección. El
// docente debe dictar el módulo (ModuleTeacher) y el estudiante estar inscrito
// en el curso. `readAt` marca cuándo el receptor lo leyó (para los no leídos).
model ChatMessage {
  id        String       @id @default(uuid())
  moduleId  String
  module    CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  studentId String
  student   User         @relation("ChatStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   User         @relation("ChatTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  senderId  String // quién envió (igual a studentId o a teacherId)
  sender    User         @relation("ChatSender", fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  readAt    DateTime? // cuándo lo leyó el receptor (null = no leído)
  createdAt DateTime     @default(now())

  @@index([moduleId, studentId, teacherId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

// Entrega de un estudiante para un contenido de tipo ACTIVITY. Calificada por el
// docente.
model Submission {
  id          String           @id @default(uuid())
  contentId   String
  content     ModuleContent    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  studentId   String
  student     User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  text        String? // texto de la entrega
  fileUrl     String? // archivo adjunto único (Tarea/ASSIGNMENT — ruta /files/...)
  status      SubmissionStatus @default(PENDING)
  score       Decimal?         @db.Decimal(5, 2)
  feedback    String?
  submittedAt DateTime?
  gradedById  String?
  gradedBy    User?            @relation("SubmissionGrader", fields: [gradedById], references: [id], onDelete: SetNull)
  gradedAt    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  deliveries ProjectDelivery[] // historial de entregas (Proyecto/PROJECT)

  @@unique([contentId, studentId])
  @@index([studentId])
  @@map("submissions")
}

// Una entrega individual dentro del historial de un Proyecto (PROJECT). Cada vez
// que el estudiante entrega se crea una fila nueva (nunca reemplaza a las
// anteriores), de modo que la `Submission` conserva el historial completo. La
// calificación sigue siendo una sola sobre la `Submission` (no por entrega). La
// Tarea (ASSIGNMENT) no usa este modelo: guarda su archivo único en
// `Submission.fileUrl`.
model ProjectDelivery {
  id           String     @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  order        Int // número de entrega (1, 2, 3…)
  text         String? // nota opcional de esta entrega
  createdAt    DateTime   @default(now())

  files SubmissionFile[] // archivos adjuntos de esta entrega

  @@index([submissionId])
  @@map("project_deliveries")
}

// Archivo adjunto de una entrega de Proyecto (pertenece a una `ProjectDelivery`).
// Espeja a `FolderFile`.
model SubmissionFile {
  id         String          @id @default(uuid())
  deliveryId String
  delivery   ProjectDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  order      Int // posición dentro de la entrega
  name       String // nombre visible (nombre original del archivo)
  url        String // ruta /files/...
  size       Int? // tamaño en bytes (opcional)
  createdAt  DateTime        @default(now())

  @@index([deliveryId])
  @@map("submission_files")
}

// Mensaje de un foro de discusión público. Pertenece a un ModuleContent de tipo
// ACTIVITY con activityType = FORUM. A diferencia del chat (1 a 1 privado), el
// hilo lo ven todos los inscritos + docentes del módulo. `parentId` apunta al
// mensaje al que responde (null = mensaje raíz; un solo nivel de anidación).
model ForumPost {
  id        String        @id @default(uuid())
  contentId String
  content   ModuleContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    ForumPost?    @relation("ForumReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   ForumPost[]   @relation("ForumReplies")
  body      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([contentId, createdAt])
  @@index([authorId])
  @@map("forum_posts")
}

// ── Motor de Cuestionario/Examen ─────────────────────────────────────────────

// Una pregunta de una actividad QUIZ/EXAM. `points` es su puntaje; la suma de
// los puntajes se escala a la `maxScore` de la actividad al calificar.
model Question {
  id        String        @id @default(uuid())
  contentId String
  content   ModuleContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  order     Int // posición en el cuestionario
  type      QuestionType
  prompt    String // enunciado
  points    Decimal       @default(1) @db.Decimal(6, 2)

  // TRUE_FALSE: respuesta correcta. SHORT_TEXT: respuestas aceptadas (se
  // normalizan al comparar). SINGLE/MULTIPLE_CHOICE: usan `options`.
  boolAnswer      Boolean?
  acceptedAnswers String[] @default([])

  options QuestionOption[]
  answers QuizAnswer[]

  @@index([contentId, order])
  @@map("questions")
}

// Una opción de una pregunta de opción múltiple.
model QuestionOption {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order      Int
  text       String
  isCorrect  Boolean  @default(false)

  @@index([questionId])
  @@map("question_options")
}

// Intento de un estudiante en un cuestionario/examen. `autoScore` es lo
// autocalificado; `manualScore` lo que el docente sumó por los ensayos;
// `totalScore` la nota final escalada a la maxScore de la actividad.
model QuizAttempt {
  id            String            @id @default(uuid())
  contentId     String
  content       ModuleContent     @relation(fields: [contentId], references: [id], onDelete: Cascade)
  studentId     String
  student       User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attemptNumber Int               @default(1)
  status        QuizAttemptStatus @default(IN_PROGRESS)
  startedAt     DateTime          @default(now())
  submittedAt   DateTime?
  autoScore     Decimal?          @db.Decimal(6, 2)
  manualScore   Decimal?          @db.Decimal(6, 2)
  totalScore    Decimal?          @db.Decimal(6, 2)

  answers QuizAnswer[]

  @@unique([contentId, studentId, attemptNumber])
  @@index([studentId])
  @@map("quiz_attempts")
}

// Respuesta de un estudiante a una pregunta dentro de un intento.
model QuizAnswer {
  id          String      @id @default(uuid())
  attemptId   String
  attempt     QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOptionIds String[] @default([]) // SINGLE/MULTIPLE_CHOICE
  boolValue   Boolean? // TRUE_FALSE
  textValue   String? // SHORT_TEXT / ESSAY
  isCorrect   Boolean? // null para ESSAY hasta corregir
  pointsAwarded Decimal? @db.Decimal(6, 2)

  @@unique([attemptId, questionId])
  @@index([questionId])
  @@map("quiz_answers")
}

// Nota final de un estudiante en un módulo. El conjunto de las notas de un
// estudiante conforma su kárdex.
model ModuleGrade {
  id           String            @id @default(uuid())
  studentId    String
  student      User              @relation("StudentGrades", fields: [studentId], references: [id], onDelete: Cascade)
  moduleId     String
  module       CourseModule      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  finalScore   Decimal?          @db.Decimal(5, 2)
  status       ModuleGradeStatus @default(IN_PROGRESS)
  observations String?
  gradedById   String?
  gradedBy     User?             @relation("ModuleGrader", fields: [gradedById], references: [id], onDelete: SetNull)
  gradedAt     DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([studentId, moduleId])
  @@index([moduleId])
  @@map("module_grades")
}
